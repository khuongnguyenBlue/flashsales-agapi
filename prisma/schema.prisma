// Schema for the FlashSale backend.
// Source of truth: docs/superpowers/specs/<spec> §10.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum OtpChannel {
  EMAIL
  PHONE
}

enum OutboxStatus {
  PENDING
  PROCESSED
  DEAD_LETTER
}

model User {
  id           String     @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  email        String?    @unique
  phone        String?    @unique
  passwordHash String     @map("password_hash")
  status       UserStatus @default(PENDING_VERIFICATION)
  balanceCents BigInt     @default(0) @map("balance_cents")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  otpCodes  OtpCode[]
  purchases Purchase[]

  @@map("users")
}

model OtpCode {
  id         String     @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  userId     String     @db.Uuid @map("user_id")
  channel    OtpChannel
  hashedCode String     @map("hashed_code")
  expiresAt  DateTime   @map("expires_at")
  used       Boolean    @default(false)
  sent       Boolean    @default(false)
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel, used, expiresAt], name: "idx_otp_lookup")
  @@map("otp_codes")
}

model Product {
  id          String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  sku         String   @unique @db.VarChar(255)
  name        String   @db.VarChar(255)
  description String?
  stock       BigInt
  priceCents  BigInt   @map("price_cents")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  flashSaleItems FlashSaleItem[]

  @@map("products")
}

model FlashSale {
  id        String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  name      String   @db.VarChar(255)
  startsAt  DateTime @map("starts_at")
  endsAt    DateTime @map("ends_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items FlashSaleItem[]

  @@index([startsAt, endsAt], name: "idx_flash_sales_window")
  @@map("flash_sales")
}

model FlashSaleItem {
  id          String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  flashSaleId String   @db.Uuid @map("flash_sale_id")
  productId   String   @db.Uuid @map("product_id")
  quantity    Int
  sold        Int      @default(0)
  priceCents  BigInt   @map("price_cents")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  flashSale FlashSale  @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id])
  purchases Purchase[]

  @@unique([flashSaleId, productId])
  @@index([flashSaleId], name: "idx_flash_sale_items_sale")
  @@map("flash_sale_items")
}

model Purchase {
  id              String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  userId          String   @db.Uuid @map("user_id")
  flashSaleItemId String   @db.Uuid @map("flash_sale_item_id")
  day             DateTime @db.Date
  priceCents      BigInt   @map("price_cents")
  idempotencyKey  String   @unique @db.Uuid @map("idempotency_key")
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id])
  flashSaleItem FlashSaleItem @relation(fields: [flashSaleItemId], references: [id])

  @@unique([userId, day])
  @@map("purchases")
}

model Outbox {
  id             BigInt       @id @default(autoincrement())
  type           String
  payload        Json
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  visibleAt      DateTime     @default(dbgenerated("CURRENT_TIMESTAMP")) @map("visible_at")
  lastError      String?      @map("last_error")
  idempotencyKey String?      @db.Uuid @map("idempotency_key")
  createdAt      DateTime     @default(now()) @map("created_at")
  processedAt    DateTime?    @map("processed_at")

  // Note: Prisma's @@index doesn't emit a partial WHERE clause for Postgres;
  // the partial index `idx_outbox_poll` is added in the manual migration step.
  @@index([idempotencyKey], name: "idx_outbox_idempotency")
  @@map("outbox")
}
