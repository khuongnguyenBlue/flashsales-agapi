# App
NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgresql://flashsale:flashsale@postgres:5432/flashsale?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT (HS256 for MVP — base64-encoded shared secret, ≥32 chars when decoded)
JWT_PRIVATE_KEY_BASE64=Zmxhc2hzYWxlLW12cC1zZWNyZXQtMzItY2hhcnMtbWluaW11bSE=
JWT_PUBLIC_KEY_BASE64=Zmxhc2hzYWxlLW12cC1zZWNyZXQtMzItY2hhcnMtbWluaW11bSE=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Bcrypt
BCRYPT_COST=12

# Business
SERVER_TIMEZONE=Asia/Ho_Chi_Minh
OTP_TTL_SECONDS=300
# AES-256-GCM key for OTP encryption — REQUIRED: run `openssl rand -hex 32` and paste here
OTP_ENCRYPTION_KEY=<run: openssl rand -hex 32>

# Worker
OUTBOX_POLL_INTERVAL_MS=200
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10

# CORS — comma-separated origins; leave empty to disable CORS entirely
CORS_ORIGINS=http://localhost:5173

# Disables ALL rate limiting (login, purchase, etc.) when set to true.
# Set to true only while running `npx tsx load/setup.ts` to avoid the
# IP-based login bucket exhausting during bulk user authentication.
# IMPORTANT: reset to false before running the k6 load test — otherwise
# purchase rate limits are also disabled and results won't reflect production.
RATE_LIMIT_DISABLED=false
